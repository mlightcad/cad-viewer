{
  "name": "@mlightcad/cad-html-exporter",
  "private": true,
  "version": "1.5.1",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mlightcad/cad-viewer.git"
  },
  "files": [
    "dist",
    "lib",
    "README.md",
    "package.json"
  ],
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    },
    "./viewer-runtime": {
      "import": "./dist/viewer-runtime.iife.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist lib tsconfig.tsbuildinfo",
    "build": "tsc && vite build && vite build --config vite.viewer.config.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix --quiet src/"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@mlightcad/data-model": "^1.7.40",
    "@mlightcad/three-renderer": "workspace:*",
    "@types/jest": "^29.5.12",
    "@types/three": "^0.172.0",
    "three": "^0.172.0"
  },
  "peerDependencies": {
    "@mlightcad/data-model": "^1.7.40",
    "@mlightcad/three-renderer": "^1.5.1",
    "three": "^0.172.0"
  }
}
