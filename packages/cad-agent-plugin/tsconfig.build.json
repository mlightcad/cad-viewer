{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./lib",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "paths": {
      "@mlightcad/cad-agent-plugin": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/vue-shim.d.ts"]
}
